# YaPsec example environment configuration
# Copy to .env and edit values for your machine/lab.

# --- Runtime host/ports (used by run.sh) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

# --- Frontend explicit API/WS targets (optional) ---
# Leave blank to use Vite proxy defaults.
VITE_API_URL=
VITE_WS_URL=

# --- API security hardening ---
# Required for remote (non-localhost) API usage.
# Keep blank for localhost-only mode.
YAPSEC_API_KEY=

# --- Optional AI executive summary ---
OPENAI_API_KEY=

# --- Privileged operations ---
# Enable one-click package installs through backend API (lab only).
YAPSEC_ALLOW_SUDO_INSTALL=0

# Enable remediation apply/rollback actions (lab only).
YAPSEC_ALLOW_AUTO_FIX=0

# --- YaPMetasploit module bridge ---
# Set to 1 to enable /api/yapmetasploit routes.
YAPSEC_ENABLE_YAPMETASPLOIT_MODULE=0

# Optional command override for external YaPMetasploit program.
# If empty, YaPsec auto-tries: yapmetasploit, yapmetasploint
YAPMETASPLOIT_CMD=

# Optional absolute path to desktop GUI entrypoint from Xydroc-IO/YaP-Metasploit-GUI.
# Example: /home/<user>/YaP-Metasploit-GUI/core/metasploit_gui.py
YAPMETASPLOIT_GUI_ENTRY=
